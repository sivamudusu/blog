<!DOCTYPE html>
<html lang="en">
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2Z352MQ8QV"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-2Z352MQ8QV');
</script>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Meta Tags -->
    <meta name="description" content="{% if description %}{{ description }}{% else %}Discover in-depth tutorials and articles on web development, DevOps, and technology. Expert insights by Shiva Mudusu.{% endif %}">
    <meta name="keywords" content="{% if keywords %}{{ keywords }}{% else %}web development, devops, programming, tutorials, technology{% endif %}">
    <meta name="author" content="{% if author %}{{ author }}{% else %}Shiva Mudusu{% endif %}">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <meta name="language" content="English">
    <meta name="revisit-after" content="7 days">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="{% if page.url == '/' %}website{% else %}article{% endif %}">
    <meta property="og:url" content="https://devtalkss.netlify.app{{ page.url or '/' }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{% if description %}{{ description }}{% else %}Discover in-depth tutorials and articles on web development, DevOps, and technology.{% endif %}">
    <meta property="og:image" content="{% if image %}https://devtalkss.netlify.app{{ image }}{% else %}https://devtalkss.netlify.app/assets/logo-color.png{% endif %}">
    <meta property="og:site_name" content="Blog">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://devtalkss.netlify.app{{ page.url or '/' }}">
    <meta property="twitter:title" content="{{ title }}">
    <meta property="twitter:description" content="{% if description %}{{ description }}{% else %}Discover in-depth tutorials and articles on web development, DevOps, and technology.{% endif %}">
    <meta property="twitter:image" content="{% if image %}https://devtalkss.netlify.app{{ image }}{% else %}https://devtalkss.netlify.app/assets/logo-color.png{% endif %}">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://devtalkss.netlify.app{{ page.url or '/' }}">

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Blog RSS Feed" href="/feed.xml">

    <title>{{ title }}{% if page.url != '/' %} - Blog{% endif %}</title>

    <!-- Fonts with font-display swap for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="shortcut icon" href="/assets/favcon2.png" type="image/x-icon">
    <link rel="apple-touch-icon" href="/assets/favcon2.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"></noscript>

    <!-- Styles (critical path) -->
    <link rel="stylesheet" href="/styles.css">

    <!-- Syntax Highlighting (non-blocking) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.25.0/themes/prism-tomorrow.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.25.0/themes/prism-tomorrow.min.css"></noscript>
</head>
<body>
    {% include 'header.njk' %}

    {{ content | safe }}

    {% include 'footer.njk' %}

    <!-- Deferred non-critical scripts -->
    <script defer src="/theme.js"></script>
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.25.0/prism.min.js"></script>
</body>
</html>
