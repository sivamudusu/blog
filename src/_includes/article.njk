---
layout : base.njk
---

<!-- Schema.org Markup for Blog Post -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description or title }}",
  "image": "{% if image %}https://devtalkss.netlify.app{{ image }}{% endif %}",
  "datePublished": "{{ date | iso8601 }}",
  "author": {
    "@type": "Person",
    "name": "{{ author or 'Shiva Mudusu' }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Blog",
    "logo": {
      "@type": "ImageObject",
      "url": "https://devtalkss.netlify.app/assets/logo-color.png"
    }
  }
}
</script>

<article class="main-article" itemscope itemtype="https://schema.org/BlogPosting">
    <div class="article-content">
        <div class="article-header">
            <h1 class="article-title">{{ title }}</h1>
            <div class="article-meta">
                <div class="meta-item">
                    <i class="fas fa-calendar-alt"></i>
                    <time datetime="{{date | iso8601}}">{{ date | postDate }}</time>
                </div>
                {% if author %}
                    <div class="meta-item">
                        <i class="fas fa-user"></i>
                        <span>{{ author }}</span>
                    </div>
                {% endif %}
                <div class="meta-item reading-time">
                    <i class="fas fa-clock"></i>
                    <span>{{ (content | wordcount / 200) | round }} min read</span>
                </div>
            </div>
        </div>

        {% if image %}
            <img src="{{image}}" alt="{{imageAlt}}" class="article-featured-image" fetchpriority="high" loading="eager">
        {% endif %}

        <div class="article-body">
            {{ content | safe }}
        </div>
    </div>
</article>